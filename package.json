{
  "name": "eventflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "echo '[boot] prisma migrate deploy' && ( npx prisma migrate deploy || ( echo '[boot] baselining pre-existing database (resolve 0_init)' && npx prisma migrate resolve --applied 0_init && npx prisma migrate deploy ) ) && echo '[boot] starting next on 0.0.0.0:'$PORT && next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "worker": "tsx src/server/worker.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@sentry/nextjs": "^8.55.2",
    "@sentry/node": "^10.66.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "ics": "^3.7.6",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "lucide-react": "^1.24.0",
    "next": "14.2.35",
    "otplib": "^12.0.1",
    "pino": "^9.3.2",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.52.1",
    "resend": "^3.5.0",
    "stripe": "^16.6.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.12",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.40",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
