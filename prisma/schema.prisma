// EventFlow — Prisma schema
// PostgreSQL 16

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── ENUMS ───────────────────────────

enum Role {
  ATTENDEE
  ORGANIZER
  STAFF
  VOLUNTEER    // similar permissions to STAFF (check-in only) but tracked separately
  ADMIN        // org-scoped admin (manages their own org)
  SUPERADMIN   // platform-wide admin (you/AITS) — can create orgs, view all
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum TicketTypeKind {
  FREE
  GENERAL
  EARLY_BIRD
  VIP
  STUDENT
  GROUP
  CUSTOM
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum QuestionType {
  TEXT
  LONG_TEXT
  DROPDOWN
  RADIO
  CHECKBOX
  EMAIL
  PHONE
  NUMBER
}

enum EmailKind {
  CONFIRMATION
  REMINDER_30D
  REMINDER_7D
  REMINDER_1D
  REMINDER_1H
  CANCELLATION
  REFUND
  REFUND_REQUEST_RECEIVED
  REFUND_REQUEST_APPROVED
  REFUND_REQUEST_DENIED
  WAITLIST_PROMOTED
  ABANDONED_CART
  ORGANIZER_BLAST
  POST_EVENT
  VENDOR_APPLICATION_RECEIVED
}

enum RefundRequestStatus {
  OPEN
  APPROVED
  DENIED
  CANCELLED
}

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  CONVERTED
  EXPIRED
  LEFT
}

enum SubscriptionPlan {
  FREE         // default
  SINGLE_EVENT // one-time payment per event credit
  STARTER      // $24.99/mo, 3 events/month
  PRO          // $29/mo, unlimited
  ENTERPRISE   // custom, set by SUPERADMIN manually
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  NONE         // no active subscription (Free plan)
}

enum VendorApplicationStatus {
  PENDING       // submitted, awaiting organizer review
  APPROVED      // organizer accepted; payment link sent
  REJECTED      // organizer declined
  PAID          // vendor paid; treated as a confirmed registration
  REFUNDED      // organizer refunded the vendor's booth payment
  WITHDRAWN     // vendor withdrew before approval
}

// ─────────────────────────── MODELS ──────────────────────────

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  bannerUrl    String?      // wide hero image shown on /o/[slug] (optional)
  brandColor   String?      // hex like "#1F3A8A"; used as the primary accent color
  tagline      String?      // short marketing line shown under the org name
  aboutBlurb   String?  @db.Text  // longer org description shown on the public org page
  website      String?
  contactEmail String?
  contactPhone String?
  // Mailing address — captured during signup (required for new orgs); legacy
  // rows may be null until the owner completes it on /dashboard/settings.
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  country      String?
  fromEmail    String?      // custom sender for transactional emails (requires Resend domain verification)
  fromName     String?      // display name on emails (e.g. "Harmony Lodge Events")
  taxRatePct   Decimal? @db.Decimal(5, 2)
  // When true, Stripe's card processing fee (2.9% + $0.30) is added as a line
  // item to every paid registration in this org. The attendee pays it on top
  // of the ticket; the organizer's payout is unchanged. SUPERADMIN-controlled
  // from /admin/orgs/[id] — replaces the now-deprecated Event.passProcessingFee.
  passProcessingFee Boolean @default(false)
  // Stripe Connect (Express) — each org gets their own Stripe account so payments flow to them directly
  stripeAccountId                String?  @unique  // acct_… returned by stripe.accounts.create
  stripeAccountChargesEnabled    Boolean  @default(false)  // can they accept payments?
  stripeAccountPayoutsEnabled    Boolean  @default(false)  // will Stripe send them payouts?
  stripeAccountDetailsSubmitted  Boolean  @default(false)  // did they finish onboarding?
  stripeAccountStatus            String?  // optional human-readable: "pending", "verified", "restricted", "rejected"
  /// When true, Stripe pays this org daily. When false (default for new signups),
  /// payouts are set to "manual" at onboarding and released per-event by the worker
  /// one day after the event ends — protecting the platform from sell-then-cancel fraud.
  /// Existing orgs were grandfathered to true; graduates flip to true after 5 clean events.
  fastPayoutsEnabled             Boolean  @default(false)

  // Subscription / billing
  stripeCustomerId            String?  @unique
  subscriptionPlan            SubscriptionPlan   @default(FREE)
  subscriptionStatus          SubscriptionStatus @default(NONE)
  stripeSubscriptionId        String?  @unique
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionCancelAtPeriodEnd Boolean @default(false)
  /// Number of "single event" credits remaining (incremented per one-time purchase, decremented when an event is published)
  singleEventCredits          Int      @default(0)
  /// false = org just signed up and hasn't picked a plan yet. While false, the dashboard locks them to /dashboard/billing.
  planSelected                Boolean  @default(true)
  /// Per-org plan limit overrides set by a SUPERADMIN (see effectivePlan / applyOverrides in src/lib/plans.ts).
  /// Shape: { monthlyEventLimit?, registrationLimitPerEvent?, emailCampaignsPerEvent? } where a present key
  /// replaces the catalog value (null = unlimited) and an absent key falls back to the plan default.
  planOverrides               Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  members         User[]
  events          Event[]
  auditLogs       AuditLog[]
  refundRequests  RefundRequest[]
  pendingInvites  PendingInvite[]
  billingInvoices BillingInvoice[]
  disputes        Dispute[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  emailVerified  Boolean  @default(false)
  passwordHash   String?
  // NEW-02: monotonic session epoch. A session JWT carries the value it was
  // signed with; getSession rejects the token if this has since been bumped.
  // Incremented on password reset to log out all existing sessions.
  sessionVersion Int      @default(1)
  // MFA (TOTP). mfaSecret is the AES-256-GCM-encrypted base32 secret; recovery
  // codes are stored as SHA-256 hashes (single-use). Opt-in for staff roles.
  mfaEnabled       Boolean  @default(false)
  mfaSecret        String?
  mfaRecoveryCodes String[] @default([])
  firstName      String?
  lastName       String?
  phone          String?
  // Personal mailing address — captured for team members so an organizer can
  // ship credentials, swag, or paperwork to staff. Optional for all roles.
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  zipCode        String?
  country        String?
  role           Role     @default(ATTENDEE)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastLoginAt    DateTime?
  deletedAt      DateTime?

  registrations  Registration[]
  auditLogs      AuditLog[]
  referralLinks  ReferralLink[]
  waitlistEntries Waitlist[]
  sessions       Session[]
  eventAssignments EventAssignment[]
  passwordResets PasswordReset[]

  @@index([organizationId])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// One-time, single-use email sign-in tokens (passwordless / "magic link").
// The raw token is emailed; only its SHA-256 hash is stored, so a DB dump
// can't be used to forge a sign-in. Consumed exactly once, expires in 15 min.
model MagicLink {
  id         String   @id @default(cuid())
  email      String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("magic_links")
}

// Single-use, hashed password-reset tokens for users who have a password
// (organizers/staff). Same hash-at-rest, single-use, short-TTL design as
// MagicLink, but tied to a specific user since the reset updates their hash.
model PasswordReset {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model Event {
  id                 String      @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug               String      // unique per-organization (not globally)
  name               String
  description        String      @db.Text
  shortDescription   String?
  category           String?
  status             EventStatus @default(DRAFT)
  // true once a single-event credit has been spent to unlock premium features
  // (unlimited registrations, vendor flow, custom branding, more broadcasts).
  isPremium          Boolean     @default(false)
  startAt            DateTime
  endAt              DateTime
  timezone           String      @default("UTC")
  capacity           Int?        // null = unlimited
  /// Set by the worker once this event's held funds have been paid out to the
  /// organizer (1 day after endAt, for orgs on held/manual payouts). Null = not
  /// yet released, or the org is on fast payouts (Stripe pays them directly).
  payoutReleasedAt   DateTime?
  /// Set by cancelEventAction when an organizer/admin CANCELS an event (distinct
  /// from a soft delete). The event stays visible as "cancelled" (deletedAt null),
  /// and the worker auto-refunds every paid attendee/vendor and emails them.
  cancelledAt        DateTime?
  cancelReason       String?     @db.Text
  maxPerOrder        Int?        @default(10)
  refundPolicy       String?     @db.Text
  cancellationPolicy String?     @db.Text
  taxRatePct         Decimal?    @db.Decimal(5, 2)
  passProcessingFee  Boolean     @default(false)
  // Presale (early-bird) discount: while now < presaleEndsAt, ticket prices are
  // reduced by presalePercent. After the date, pricing reverts to regular.
  // Both null = no presale. Enabled = both set and percent > 0.
  presalePercent     Decimal?    @db.Decimal(5, 2)
  presaleEndsAt      DateTime?
  waitlistEnabled    Boolean     @default(true)
  bannerUrl          String?
  // Banner crop framing: object-position-x / object-position-y as 0-100
  // percentages, and a zoom multiplier (1.0 = no zoom, capped at 3.0 in the
  // UI). Lets organizers re-frame an uploaded image without re-uploading it.
  bannerPositionX    Float    @default(50)
  bannerPositionY    Float    @default(50)
  bannerZoom         Float    @default(1)
  // When true the banner uses object-fit:contain on the public page — shows
  // the whole image at the cost of letterbox/pillarbox space. When false
  // (default) it uses object-fit:cover with the position/zoom framing above.
  bannerFitToFrame   Boolean  @default(false)
  promoVideoUrl      String?
  contactEmail       String?
  vendorRegistrationEnabled Boolean @default(false)
  vendorApplicationNotes    String? @db.Text // appears on the vendor form, e.g. "Booths are 10x10. Includes table + chairs."
  defaultVendorPriceCents   Int     @default(0) // default booth price; organizer can override per-vendor at approval time
  isPrivate                 Boolean @default(false)  // true = hidden from yourevents.app homepage & org public page; direct link still works
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  publishedAt        DateTime?
  deletedAt          DateTime?

  location           EventLocation?
  speakers           Speaker[]
  media              EventMedia[]
  tags               EventTag[]
  ticketTypes        TicketType[]
  customQuestions    CustomQuestion[]
  registrations      Registration[]
  promoCodes         PromoCode[]
  referralLinks      ReferralLink[]
  waitlist           Waitlist[]
  emailCampaigns     EmailCampaign[]
  abandonedCarts     AbandonedCart[]
  checkIns           CheckIn[]
  auditLogs          AuditLog[]
  vendorApplications VendorApplication[]
  refundRequests     RefundRequest[]
  assignments        EventAssignment[]
  pendingInvites     PendingInvite[]

  @@unique([organizationId, slug])
  @@index([organizationId, startAt])
  @@index([status, startAt])
  @@map("events")
}

model EventLocation {
  id            String  @id @default(cuid())
  eventId       String  @unique
  event         Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venueName     String?
  addressLine1  String
  addressLine2  String?
  city          String
  state         String?
  postalCode    String?
  country       String  @default("US")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  googlePlaceId String?
  isVirtual     Boolean @default(false)
  virtualUrl    String?

  @@map("event_locations")
}

model Speaker {
  id        String  @id @default(cuid())
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  title     String?
  bio       String? @db.Text
  photoUrl  String?
  contact   String?
  order     Int     @default(0)

  @@index([eventId])
  @@map("speakers")
}

model EventMedia {
  id        String  @id @default(cuid())
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  kind      String  @default("photo") // photo | video
  order     Int     @default(0)
  createdAt DateTime @default(now())

  @@index([eventId])
  @@map("event_media")
}

model EventTag {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag     String

  @@unique([eventId, tag])
  @@index([tag])
  @@map("event_tags")
}

model TicketType {
  id              String         @id @default(cuid())
  eventId         String
  event           Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  kind            TicketTypeKind @default(GENERAL)
  priceCents      Int            @default(0)
  currency        String         @default("USD")
  quantityTotal   Int?           // null = unlimited
  quantitySold    Int            @default(0)
  minPerOrder     Int            @default(1)
  maxPerOrder     Int?
  groupSize       Int?           // for GROUP type
  salesStartAt    DateTime?
  salesEndAt      DateTime?
  isHidden        Boolean        @default(false)
  isVendorTier    Boolean        @default(false)  // when true, this tier is offered only via the vendor application flow
  sortOrder       Int            @default(0)

  registrations   Registration[]
  vendorApplications VendorApplication[]

  @@index([eventId])
  @@map("ticket_types")
}

model CustomQuestion {
  id         String       @id @default(cuid())
  eventId    String
  event      Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  label      String
  type       QuestionType
  required   Boolean      @default(false)
  options    Json?        // string[] for dropdown/radio/checkbox
  sortOrder  Int          @default(0)

  answers    CustomAnswer[]

  @@index([eventId])
  @@map("custom_questions")
}

model Registration {
  id                String             @id @default(cuid())
  eventId           String
  event             Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypeId      String
  ticketType        TicketType         @relation(fields: [ticketTypeId], references: [id])
  userId            String?            // null for guest checkout
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  firstName         String
  lastName          String
  email             String
  phone             String?
  company           String?
  jobTitle          String?
  dietary           String?
  accessibility     String?
  specialRequests   String?

  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  zipCode           String?
  country           String?

  quantity          Int                @default(1)
  subtotalCents     Int                @default(0)
  discountCents     Int                @default(0)
  taxCents          Int                @default(0)
  feeCents          Int                @default(0)
  totalCents        Int                @default(0)
  currency          String             @default("USD")

  promoCodeId       String?
  promoCode         PromoCode?         @relation(fields: [promoCodeId], references: [id])
  referralLinkId    String?
  referralLink      ReferralLink?      @relation(fields: [referralLinkId], references: [id])

  status            RegistrationStatus @default(PENDING)
  confirmedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?

  stripeSessionId   String?
  stripePaymentIntentId String?

  /// Random secret required to view tickets on the success page / download ICS.
  /// Registration ids are cuids (guessable-ish, leak via logs/referrers); this
  /// token is the actual authorization to retrieve QR tickets. Deliberately NOT
  /// @unique: it's only compared against a row fetched by id, and adding a
  /// unique constraint makes `prisma db push` (flagless at boot) refuse the
  /// migration as potentially lossy.
  accessToken       String?

  ipAddress         String?
  userAgent         String?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  tickets           Ticket[]
  payments          Payment[]
  answers           CustomAnswer[]
  emailLogs         EmailLog[]
  refundRequests    RefundRequest[]

  @@index([eventId, status])
  @@index([email])
  @@index([stripeSessionId])
  @@unique([eventId, email]) // duplicate-email prevention per event
  @@map("registrations")
}

model RefundRequest {
  id               String              @id @default(cuid())
  registrationId   String
  registration     Registration        @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  eventId          String
  event            Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  reason           String              @db.Text
  status           RefundRequestStatus @default(OPEN)

  reviewedBy       String?
  reviewedAt       DateTime?
  reviewNote       String?             @db.Text

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([eventId, status])
  @@index([registrationId])
  @@map("refund_requests")
}

model Ticket {
  id              String   @id @default(cuid())
  registrationId  String
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  attendeeName    String
  attendeeEmail   String?
  qrCodeHash      String   @unique  // SHA-256 of signed JWT
  qrToken         String   @db.Text // signed JWT (single-use validated at scan)
  isValid         Boolean  @default(true)
  invalidatedAt   DateTime?
  invalidReason   String?
  createdAt       DateTime @default(now())

  checkIn         CheckIn?

  @@index([registrationId])
  @@map("tickets")
}

model CustomAnswer {
  id             String  @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  questionId     String
  question       CustomQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer         String  @db.Text

  @@unique([registrationId, questionId])
  @@map("custom_answers")
}

model Payment {
  id                    String        @id @default(cuid())
  registrationId        String
  registration          Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  amountCents           Int
  /// Our platform cut on this charge (Stripe application_fee_amount, in cents).
  /// 0 for pre-fee-tracking rows and for charges that carried no application fee.
  /// On refund the fee is reversed proportionally; net revenue prorates by amount refunded.
  platformFeeCents      Int           @default(0)
  currency              String        @default("USD")
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?
  stripeRefundId        String?
  refundedAmountCents   Int           @default(0)
  receiptUrl            String?
  invoiceUrl            String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  disputes              Dispute[]

  @@index([registrationId])
  @@map("payments")
}

/// Subscription / one-time billing invoices paid by organizations (from Stripe `invoice.paid`).
/// This is the platform's subscription revenue ledger — distinct from per-ticket platform fees.
model BillingInvoice {
  id               String        @id @default(cuid())
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  stripeInvoiceId  String        @unique
  stripeCustomerId String?
  /// Plan key inferred from the invoice line price, best-effort.
  planKey          String?
  amountPaidCents  Int           @default(0)
  currency         String        @default("USD")
  status           String        // 'paid'
  periodStart      DateTime?
  periodEnd        DateTime?
  /// Set to the Stripe invoice's paid/created time so financial windows are accurate.
  createdAt        DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@map("billing_invoices")
}

/// Card disputes / chargebacks (from Stripe `charge.dispute.*`). Pull money + fees back
/// and carry Stripe penalties, so they're tracked as a financial-risk line.
model Dispute {
  id                    String        @id @default(cuid())
  stripeDisputeId       String        @unique
  organizationId        String?
  organization          Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  paymentId             String?
  payment               Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  stripePaymentIntentId String?
  stripeChargeId        String?
  amountCents           Int           @default(0)
  currency              String        @default("USD")
  reason                String?
  /// Stripe dispute status: needs_response, under_review, won, lost, warning_*, etc.
  status                String
  /// Set to the Stripe dispute creation time.
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([organizationId, createdAt])
  @@map("disputes")
}

model PromoCode {
  id            String       @id @default(cuid())
  eventId       String
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  code          String
  discountType  DiscountType
  amountCents   Int?         // for FIXED
  percentage    Decimal?     @db.Decimal(5, 2) // for PERCENTAGE
  usageLimit    Int?
  usageCount    Int          @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  registrations Registration[]

  @@unique([eventId, code])
  @@index([code])
  @@map("promo_codes")
}

model ReferralLink {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  code          String   @unique
  label         String?
  clickCount    Int      @default(0)
  conversionCount Int    @default(0)
  createdAt     DateTime @default(now())

  registrations Registration[]
  clicks        ReferralClick[]

  @@index([eventId])
  @@map("referral_links")
}

model ReferralClick {
  id             String @id @default(cuid())
  referralLinkId String
  referralLink   ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)
  ipHash         String?
  userAgent      String?
  converted      Boolean @default(false)
  createdAt      DateTime @default(now())

  @@index([referralLinkId])
  @@map("referral_clicks")
}

model CheckIn {
  id         String   @id @default(cuid())
  ticketId   String   @unique
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scannedBy  String?  // user id of staff
  scannedAt  DateTime @default(now())
  method     String   @default("qr") // qr | manual | search
  deviceInfo String?

  @@index([eventId, scannedAt])
  @@map("check_ins")
}

model Waitlist {
  id         String         @id @default(cuid())
  eventId    String
  event      Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  email      String
  firstName  String
  lastName   String
  position   Int
  status     WaitlistStatus @default(WAITING)
  promotedAt DateTime?
  expiresAt  DateTime?
  /// Set when promoted. Carried in the promotion email's "Register" link; the
  /// registration API treats it as a held seat that bypasses the sold-out check.
  magicToken String?
  /// Stable per-entry secret for the "leave waitlist" link (set at create).
  leaveToken String?
  createdAt  DateTime       @default(now())

  @@unique([eventId, email])
  @@index([eventId, position])
  @@index([magicToken])
  @@index([leaveToken])
  @@map("waitlist")
}

model EmailCampaign {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subject     String
  bodyHtml    String   @db.Text
  bodyText    String?  @db.Text
  segment     Json?    // {status:[...], ticketTypeIds:[...]}
  scheduledAt DateTime?
  sentAt      DateTime?
  recipientsCount Int  @default(0)
  openedCount Int      @default(0)
  clickedCount Int     @default(0)
  createdAt   DateTime @default(now())

  emailLogs   EmailLog[]

  @@index([eventId])
  @@map("email_campaigns")
}

model EmailLog {
  id             String      @id @default(cuid())
  registrationId String?
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  campaignId     String?
  campaign       EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  toEmail        String
  kind           EmailKind
  subject        String
  status         EmailStatus @default(QUEUED)
  providerId     String?     // Resend message id
  errorMessage   String?
  openedAt       DateTime?
  clickedAt      DateTime?
  sentAt         DateTime?
  createdAt      DateTime    @default(now())

  @@index([toEmail])
  @@index([status])
  @@map("email_logs")
}

model AbandonedCart {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email      String
  firstName  String?
  payload    Json
  recoveredAt DateTime?
  remindedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([eventId, email])
  @@map("abandoned_carts")
}

model PendingInvite {
  id                 String       @id @default(cuid())
  token              String       @unique
  email              String
  invitedFirstName   String?      // optional pre-fill for the accept form
  invitedLastName    String?
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventId            String?      // when set, invite is scoped to a specific event
  event              Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  role               Role         @default(ORGANIZER)
  roleDescription    String?      @db.Text   // what the invitee will do (e.g. "Setup crew", "Door check-in")
  invitedBy          String?      // user id of whoever created the invite
  message            String?      @db.Text   // optional personal note from inviter, included in the email
  status             InviteStatus @default(PENDING)
  expiresAt          DateTime
  createdAt          DateTime     @default(now())
  acceptedAt         DateTime?
  acceptedByUserId   String?
  revokedAt          DateTime?

  @@index([organizationId])
  @@index([eventId])
  @@index([email])
  @@map("pending_invites")
}

// Platform-wide singleton config (one row, id = "singleton"). Currently holds
// the maintenance-mode switch; the model is named generically so future
// platform-level flags (default fee waivers, feature kill switches, etc.) can
// live alongside without another migration.
model PlatformConfig {
  id                     String    @id @default("singleton")
  maintenanceMode        Boolean   @default(false)
  maintenanceUntil       DateTime?
  maintenanceMessage     String?
  maintenanceStartedById String?
  maintenanceStartedAt   DateTime?
  updatedAt              DateTime  @updatedAt

  @@map("platform_config")
}

// Platform-admin (SUPERADMIN) invites. Unlike PendingInvite these are NOT tied
// to an organization — platform admins are org-less (and the inviting owner may
// have no org after a factory reset), so they get their own table. Accepting one
// creates a SUPERADMIN account with a strict password.
model AdminInvite {
  id               String       @id @default(cuid())
  token            String       @unique
  email            String
  invitedBy        String?      // user id of the SUPERADMIN/owner who created it
  status           InviteStatus @default(PENDING)
  expiresAt        DateTime
  createdAt        DateTime     @default(now())
  acceptedAt       DateTime?
  acceptedByUserId String?
  revokedAt        DateTime?

  @@index([email])
  @@map("admin_invites")
}

model EventAssignment {
  id              String   @id @default(cuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleDescription String?  @db.Text   // duties for THIS event (carries from the invite)
  assignedBy      String?  // user id of the organizer who assigned them
  assignedAt      DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
  @@map("event_assignments")
}

model VendorApplication {
  id                 String                  @id @default(cuid())
  eventId            String
  event              Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypeId       String?
  ticketType         TicketType?             @relation(fields: [ticketTypeId], references: [id])

  // Vendor org info
  companyName        String
  contactFirstName   String
  contactLastName    String
  email              String
  phone              String?
  website            String?
  logoUrl            String?

  // Booth + offering
  description        String                  @db.Text   // what they sell / their pitch
  productCategory    String?                            // e.g. Tech / Food / Apparel / Services
  boothPreference    String?                            // requested booth size or location
  sponsorshipLevel   String?                            // optional add-on sponsorship interest
  electricalNeeds    Boolean                 @default(false)
  additionalRequests String?                 @db.Text

  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  zipCode            String?
  country            String?

  status             VendorApplicationStatus @default(PENDING)
  submittedAt        DateTime                @default(now())
  reviewedAt         DateTime?
  reviewedBy         String?                            // user id of organizer
  rejectionReason    String?                 @db.Text
  approvalNotes      String?                 @db.Text
  quotedPriceCents   Int?                               // price organizer quoted at approval time; overrides event default

  // After approval, we mint a magic-link checkout token so the vendor can pay
  paymentLinkToken   String?                 @unique
  paymentLinkExpiresAt DateTime?
  registrationId     String?                 @unique    // set after they pay → links to the Registration row
  paidAt             DateTime?

  @@unique([eventId, email])  // one application per vendor per event
  @@index([eventId, status])
  @@map("vendor_applications")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  eventId        String?
  event          Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         String   // e.g. "event.publish", "registration.refund"
  targetType     String?
  targetId       String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}

/// Stripe delivers webhooks at-least-once; this table dedupes redeliveries.
/// A row is claimed (insert) before processing and removed if the handler
/// fails, so Stripe's retry can reprocess. Unique stripeEventId is the lock.
model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())

  @@map("webhook_events")
}
