# Copy this to .env.local and fill in real values from Railway.
# Railway → EventReg → web service → Variables tab has all of these.

# ── Core ──────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_COOKIE_NAME=eventflow_session

# ── Database ──────────────────────────────────────────────
# Either paste Railway's public connection string for prod DB,
# or spin up local Postgres: postgresql://postgres:postgres@localhost:5432/eventflow
DATABASE_URL=

# ── Redis (rate limiting) ─────────────────────────────────
# Local: redis://localhost:6379  (run `docker run -p 6379:6379 redis:7`)
# Or paste Railway's public Redis URL
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=
JWT_ISSUER=yourevents
# Separate signing key for QR ticket tokens (SEC-02). Isolates a key leak so a
# compromised session secret can't forge tickets and vice versa. Defaults to
# JWT_SECRET when unset (no breakage). NOTE: setting a NEW distinct value
# invalidates already-issued QR tickets — do the cutover between events.
QR_SECRET=

# ── Stripe (test mode) ────────────────────────────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and paste the whsec_... it prints (local webhook signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=events@yourevents.app

# ── Cloudinary (banner uploads) ───────────────────────────
# Settings → Upload → Add upload preset → Signing Mode: Unsigned
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ── Google Maps (event location embed) ────────────────────
# Restrict the key to your domains in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Admin seeding (one-time) ──────────────────────────────
SEED_SECRET=
