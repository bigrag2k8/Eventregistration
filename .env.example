# ─────────────────────────────────────────────────────────────────────────────
# YourEvents — environment variables
#
# Copy to .env.local (local dev) and fill in real values. In production these
# live on the Railway WEB service (and a few must ALSO be on the WORKER service
# — noted below). Railway → EventReg → <service> → Variables.
#
# Generate any secret with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────
NODE_ENV=development
# Public base URL — used in emails, redirects, QR/review links. Must be the real
# https:// domain in prod (e.g. https://www.yourevents.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional — name of the session cookie (defaults to a built-in if unset).
SESSION_COOKIE_NAME=eventflow_session

# ── Database — PostgreSQL (REQUIRED, web + worker) ────────
# Prod: Railway Postgres connection string. Local: docker-compose (below) or a
# local Postgres. The worker needs this too (it runs migrations + jobs).
DATABASE_URL=
# Password for the local docker-compose Postgres only (SEC-10). Required for
# `docker compose up`; make your local DATABASE_URL match it, e.g.:
#   POSTGRES_PASSWORD=$(openssl rand -hex 16)
#   DATABASE_URL=postgresql://eventflow:<that-value>@db:5432/eventflow
POSTGRES_PASSWORD=

# ── Redis — rate limiting + job queue (recommended, web + worker) ──
# Prod: Railway/Upstash Redis URL. Local: redis://localhost:6379
#   (docker run -p 6379:6379 redis:7)
# If unreachable, rate limiting falls back to a per-process in-memory limiter.
REDIS_URL=redis://localhost:6379

# ── Auth & crypto secrets (REQUIRED, web + worker) ───────
# Session-signing secret. MUST be ≥32 chars and NOT a default — production
# refuses to boot otherwise.
JWT_SECRET=
JWT_ISSUER=yourevents
# Separate signing key for QR ticket + review tokens (SEC-02): isolates a leak so
# a compromised session secret can't forge tickets. Defaults to JWT_SECRET if
# unset. MUST be set identically on the WORKER too (it signs review links) — a
# mismatch silently breaks verification. Changing it invalidates issued QR
# tickets, so cut over between events.
QR_SECRET=
# AES-256-GCM key that encrypts stored TOTP (2FA) secrets. Set this BEFORE anyone
# enrolls in MFA — changing it afterward makes existing secrets undecryptable and
# locks those users out. Defaults to JWT_SECRET if unset (a warning is logged).
MFA_SECRET=

# ── Stripe — payments & payouts (REQUIRED, web + worker) ──
# Keys: https://dashboard.stripe.com/apikeys  (test mode: /test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret. Local: run
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
# and paste the whsec_... it prints. Prod: the signing secret from your webhook
# endpoint in the Stripe dashboard. Supports a comma-separated list (e.g. one
# secret for account events + one for Connect events).
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — env-overridable so you can flip test<->live from Railway
# with no code change. Unset = the in-code test-sandbox defaults. For live,
# create the products in live mode and paste the live price_... IDs.
# (The $19 recurring-event credit is priced inline in code — no env var.)
STRIPE_PRICE_SINGLE_EVENT=
# Subscription tiers — only needed if you re-enable Starter/Pro (hidden in the
# current Free + Single-Event model).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ── Email — Resend (REQUIRED, web + worker) ──────────────
# API key: https://resend.com/api-keys  — use a Full-access / all-domains key.
# The worker sends reminder/review emails, so set this on the WORKER too.
RESEND_API_KEY=re_...
# From address — the domain must be verified in Resend.
EMAIL_FROM=Your Events App <events@yourevents.app>
# Optional — shown to users as the support contact (falls back to EMAIL_FROM).
SUPPORT_EMAIL=

# ── Owner & ops alerts ────────────────────────────────────
# The protected break-glass owner: always SUPERADMIN, can't be demoted. Set to
# your own email. Also the fallback recipient for the new-org signup alert.
OWNER_EMAIL=
# Where operational alerts go: failed reconciliations AND the "new organization
# signed up" heads-up email. Set to the inbox you watch. Falls back to
# OWNER_EMAIL if unset.
OPS_ALERT_EMAIL=

# ── Cloudinary — image uploads (banners, logos) ──────────
# cloudinary.com dashboard → cloud name; then Settings → Upload → Add upload
# preset → Signing Mode: Unsigned. Without these, image upload is disabled.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ── Google Maps — address autocomplete + event maps ──────
# This key is served to the browser (it must be — it powers client-side Maps).
# It is therefore NOT a secret; its ONLY protection is Google Cloud restrictions.
# Anyone can read it from the page source, so an UNRESTRICTED key can be copied
# and used on any site, billed to your account (verified 2026-07-19: F-14 — the
# production key was reachable and usable from an unrelated origin).
#
# In Google Cloud Console → APIs & Services → Credentials → (this key), set BOTH:
#   1. Application restriction = "Websites" (HTTP referrers). Add exactly:
#        https://www.yourevents.app/*
#        https://yourevents.app/*
#        http://localhost:3000/*        (dev only; drop in prod-only keys)
#   2. API restriction = "Restrict key" → enable ONLY the APIs actually used:
#        Maps JavaScript API, Places API, Maps Embed API, Maps Static API.
# Also set a billing budget + alert as a backstop. If the key has been public
# and unrestricted, review usage for abuse and rotate it AFTER restricting.
# This is the CANONICAL name the client loader reads — set THIS one.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
#   Optional variants also honored (server-only / legacy) — you normally don't
#   need these if the one above is set:
#   GOOGLE_MAPS_API_KEY=            # runtime-only (kept out of the client bundle)
#   NEXT_PUBLIC_GOOGLE_MAPS_KEY=    # legacy alias, fallback only

# ── Sentry — error tracking (optional but recommended) ───
# sentry.io → your project → Settings → Client Keys (DSN). A DSN is safe to
# expose. Set on BOTH web and worker for full coverage.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Admin seeding (one-time) ──────────────────────────────
# Secret gate for the seed/admin-bootstrap endpoint. Generate a random value.
SEED_SECRET=
